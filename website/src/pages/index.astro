---
import Layout from "../layouts/Layout.astro";
import Section from "../components/theme/Section.astro";
import SectionHeader from "../components/theme/SectionHeader.astro";
import Card from "../components/theme/Card.astro";
import FeatureCard from "../components/theme/FeatureCard.astro";
import heroScreenshot from "../assets/nocodo_Analysing_Own_Code.png";
import connectionScreenshot from "../assets/nocodo_Connection_Screen_Local_Remote_SSH_Options.png";
import lanConnectScreenshot from "../assets/nocodo_Connect_Remote_Within_LAN.png";
---

<Layout
    title="nocodo - AI-powered business operations platform"
    description="Run your business with open source software. AI helps every team member operate business systems, manage data, and handle IT operations."
>
    <!-- Hero Section -->
    <section
        class="relative overflow-hidden bg-gradient-to-b from-bg-primary via-bg-secondary to-bg-primary text-text-primary"
    >
        <!-- Background Pattern -->
        <div class="absolute inset-0 opacity-10">
            <svg
                class="absolute inset-0 h-full w-full"
                xmlns="http://www.w3.org/2000/svg"
            >
                <defs>
                    <pattern
                        id="grid"
                        width="32"
                        height="32"
                        patternUnits="userSpaceOnUse"
                    >
                        <path
                            d="M0 32V0h32"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1"></path>
                    </pattern>
                </defs>
                <rect width="100%" height="100%" fill="url(#grid)"></rect>
            </svg>
        </div>

        <div
            class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32"
        >
            <div class="text-center">
                <!-- Logo/Brand -->
                <h1
                    class="text-6xl sm:text-7xl lg:text-8xl font-bold mb-8 bg-gradient-to-r from-accent-emerald to-accent-cyan bg-clip-text text-transparent"
                >
                    nocodo
                </h1>

                <!-- Tagline -->
                <p
                    class="text-2xl sm:text-3xl lg:text-4xl text-text-secondary max-w-4xl mx-auto mb-6 leading-tight font-light"
                >
                    AI-powered business operations platform
                </p>

                <p
                    class="text-lg sm:text-xl text-text-tertiary max-w-3xl mx-auto mb-12"
                >
                    Run your business with open source software. AI helps every team member operate systems, access data, and manage IT operations.
                </p>

                <!-- CTA -->
                <div class="flex justify-center">
                    <a
                        href="https://github.com/brainless/nocodo"
                        class="inline-flex items-center px-8 py-4 bg-gradient-to-r from-emerald-500 to-cyan-500 hover:from-emerald-600 hover:to-cyan-600 text-white font-semibold rounded-lg shadow-lg hover:shadow-xl transition-all duration-200"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <svg
                            class="mr-3 w-6 h-6"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                            ></path>
                        </svg>
                        Star on GitHub
                    </a>
                </div>

                <p class="text-sm text-text-muted mt-8">
                    Under active development • Star and watch for updates
                </p>
            </div>
        </div>
    </section>

    <!-- Hero Screenshot - User will update -->
    <Section background="primary" paddingY="sm">
        <div class="relative">
            <img
                src={heroScreenshot.src}
                alt="nocodo in action"
                title="nocodo platform"
                class="w-full rounded-lg shadow-2xl border border-border-primary"
            />
        </div>
    </Section>

    <!-- What is nocodo Section -->
    <Section background="secondary" containerWidth="5xl">
        <SectionHeader title="What is nocodo?" />

        <Card class="p-8 sm:p-12">
            <p
                class="text-xl sm:text-2xl text-text-secondary leading-relaxed mb-6"
            >
                Run your business with open source software instead of expensive SaaS subscriptions.
            </p>
            <p class="text-lg sm:text-xl text-text-secondary leading-relaxed">
                Unlike coding agents focused on generating code, nocodo helps you deploy, integrate, and manage the software your business needs. With AI as your guide, discover the right open source tools, integrate with existing systems, and give every team member unified access to business data and operations.
            </p>
        </Card>
    </Section>

    <!-- Core Capabilities Section -->
    <Section background="primary">
        <SectionHeader
            title="Core Capabilities"
            subtitle="Everything your business needs to operate with open source"
        />

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            <Card class="p-6">
                <h3 class="text-lg font-bold text-text-primary mb-2">
                    Team Onboarding & AI Assistance
                </h3>
                <p class="text-text-tertiary">
                    AI helps new members learn systems and workflows. Every team member gets a personal AI assistant for daily work.
                </p>
            </Card>

            <Card class="p-6">
                <h3 class="text-lg font-bold text-text-primary mb-2">
                    Open Source Stack Management
                </h3>
                <p class="text-text-tertiary">
                    Discover, clone, install, and configure business applications via Git. Command discovery and execution for any software.
                </p>
            </Card>

            <Card class="p-6">
                <h3 class="text-lg font-bold text-text-primary mb-2">
                    Unified Data Access
                </h3>
                <p class="text-text-tertiary">
                    Connect emails, CRM, databases, and SaaS tools in one place. AI-powered analytics across your entire business.
                </p>
            </Card>

            <Card class="p-6">
                <h3 class="text-lg font-bold text-text-primary mb-2">
                    IT Operations Automation
                </h3>
                <p class="text-text-tertiary">
                    Database backups, Git-based deployments, software updates, and infrastructure management.
                </p>
            </Card>

            <Card class="p-6">
                <h3 class="text-lg font-bold text-text-primary mb-2">
                    SaaS Integration
                </h3>
                <p class="text-text-tertiary">
                    Integrate existing SaaS tools via APIs. Combine open source and commercial software to reduce vendor lock-in.
                </p>
            </Card>

            <Card class="p-6">
                <h3 class="text-lg font-bold text-text-primary mb-2">
                    Business-Wide Collaboration
                </h3>
                <p class="text-text-tertiary">
                    Shared access to systems, AI-guided onboarding, unified data visibility, and role-based access control.
                </p>
            </Card>
        </div>

    </Section>

    <!-- Who Uses nocodo -->
    <Section background="secondary">
        <SectionHeader title="Who Uses nocodo?" subtitle="Designed for everyone in your business" />

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            <Card class="p-6">
                <h3 class="text-lg font-bold text-text-primary mb-2">
                    Sales Teams
                </h3>
                <p class="text-text-tertiary">
                    Access CRM data and customer analytics with AI assistance
                </p>
            </Card>

            <Card class="p-6">
                <h3 class="text-lg font-bold text-text-primary mb-2">
                    Support Teams
                </h3>
                <p class="text-text-tertiary">
                    Manage tickets and customer information across all systems
                </p>
            </Card>

            <Card class="p-6">
                <h3 class="text-lg font-bold text-text-primary mb-2">
                    Operations
                </h3>
                <p class="text-text-tertiary">
                    Run backups, deployments, and system maintenance
                </p>
            </Card>

            <Card class="p-6">
                <h3 class="text-lg font-bold text-text-primary mb-2">
                    New Hires
                </h3>
                <p class="text-text-tertiary">
                    Get onboarded with AI guidance and faster time to productivity
                </p>
            </Card>

            <Card class="p-6">
                <h3 class="text-lg font-bold text-text-primary mb-2">
                    Managers
                </h3>
                <p class="text-text-tertiary">
                    Gain visibility across all business systems and data
                </p>
            </Card>

            <Card class="p-6">
                <h3 class="text-lg font-bold text-text-primary mb-2">
                    Developers
                </h3>
                <p class="text-text-tertiary">
                    When custom code is actually needed
                </p>
            </Card>
        </div>
    </Section>

    <!-- Business Use Cases -->
    <Section background="primary">
        <SectionHeader title="Business Use Cases" />

        <div class="space-y-6">
            <Card class="p-6">
                <h3 class="text-xl font-bold text-text-primary mb-3">
                    Onboarding New Team Members
                </h3>
                <p class="text-text-secondary">
                    AI teaches them your systems and workflows. Guided access to relevant data and tools. Faster time to productivity.
                </p>
            </Card>

            <Card class="p-6">
                <h3 class="text-xl font-bold text-text-primary mb-3">
                    Daily Business Operations
                </h3>
                <p class="text-text-secondary">
                    Sales reps query CRM and analytics. Support teams access customer data across systems. Admin tasks automated with AI assistance.
                </p>
            </Card>

            <Card class="p-6">
                <h3 class="text-xl font-bold text-text-primary mb-3">
                    Cross-System Data Analysis
                </h3>
                <p class="text-text-secondary">
                    Combine data from emails, CRM, databases, and SaaS tools. AI helps answer business questions across all your data without switching between tools.
                </p>
            </Card>

            <Card class="p-6">
                <h3 class="text-xl font-bold text-text-primary mb-3">
                    IT Operations & Maintenance
                </h3>
                <p class="text-text-secondary">
                    Automated backups and monitoring. Software updates managed by AI. Infrastructure changes tracked in Git.
                </p>
            </Card>

            <Card class="p-6">
                <h3 class="text-xl font-bold text-text-primary mb-3">
                    Building with Open Source
                </h3>
                <p class="text-text-secondary">
                    Reduce SaaS costs with open source alternatives. Maintain control of your data and infrastructure. Customize software to your exact needs.
                </p>
            </Card>
        </div>
    </Section>

    <!-- How It Works -->
    <Section background="secondary">
        <SectionHeader title="How It Works" />

        <div class="grid lg:grid-cols-2 gap-8">
            <Card class="p-8">
                <div class="flex items-center mb-6">
                    <div
                        class="w-12 h-12 bg-accent-cyan/10 rounded-lg flex items-center justify-center mr-4"
                    >
                        <svg
                            class="w-6 h-6 text-accent-cyan"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="text-2xl font-bold text-text-primary">
                        Desktop App
                    </h3>
                </div>
                <p class="text-text-secondary mb-4 leading-relaxed">
                    Your personal AI assistant
                </p>
                <ul class="space-y-3 text-text-secondary">
                    <li class="flex items-start">
                        <svg
                            class="w-5 h-5 text-accent-cyan mr-3 mt-0.5 flex-shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span>Secure access to all business systems</span>
                    </li>
                    <li class="flex items-start">
                        <svg
                            class="w-5 h-5 text-accent-cyan mr-3 mt-0.5 flex-shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span>AI guides you through operations</span>
                    </li>
                    <li class="flex items-start">
                        <svg
                            class="w-5 h-5 text-accent-cyan mr-3 mt-0.5 flex-shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span>Native app for every team member</span>
                    </li>
                </ul>
            </Card>

            <Card class="p-8">
                <div class="flex items-center mb-6">
                    <div
                        class="w-12 h-12 bg-accent-emerald/10 rounded-lg flex items-center justify-center mr-4"
                    >
                        <svg
                            class="w-6 h-6 text-accent-emerald"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"
                            ></path>
                        </svg>
                    </div>
                    <h3 class="text-2xl font-bold text-text-primary">
                        Manager
                    </h3>
                </div>
                <p class="text-text-secondary mb-4 leading-relaxed">
                    Your business software hub
                </p>
                <ul class="space-y-3 text-text-secondary">
                    <li class="flex items-start">
                        <svg
                            class="w-5 h-5 text-accent-emerald mr-3 mt-0.5 flex-shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span>Runs on your infrastructure (cloud or on-premise)</span>
                    </li>
                    <li class="flex items-start">
                        <svg
                            class="w-5 h-5 text-accent-emerald mr-3 mt-0.5 flex-shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span>Manages all open source software installations</span>
                    </li>
                    <li class="flex items-start">
                        <svg
                            class="w-5 h-5 text-accent-emerald mr-3 mt-0.5 flex-shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"></path>
                        </svg>
                        <span>Git-based for version control and reproducibility</span>
                    </li>
                </ul>
            </Card>
        </div>
    </Section>

    <!-- Privacy & Control -->
    <Section background="primary" containerWidth="5xl">
        <SectionHeader title="Privacy & Control" />

        <div class="grid md:grid-cols-2 gap-6">
            <Card class="p-6">
                <div class="flex items-center mb-3">
                    <svg
                        class="w-6 h-6 text-accent-emerald mr-3"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                        ></path>
                    </svg>
                    <h3 class="text-lg font-bold text-text-primary">
                        Your Infrastructure
                    </h3>
                </div>
                <p class="text-text-tertiary">
                    Run on your own cloud servers - you control everything
                </p>
            </Card>

            <Card class="p-6">
                <div class="flex items-center mb-3">
                    <svg
                        class="w-6 h-6 text-accent-emerald mr-3"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"
                        ></path>
                    </svg>
                    <h3 class="text-lg font-bold text-text-primary">
                        Your API Keys
                    </h3>
                </div>
                <p class="text-text-tertiary">
                    Bring your own keys for OpenAI, Anthropic, or any LLM
                    provider
                </p>
            </Card>

            <Card class="p-6">
                <div class="flex items-center mb-3">
                    <svg
                        class="w-6 h-6 text-accent-emerald mr-3"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                        ></path>
                    </svg>
                    <h3 class="text-lg font-bold text-text-primary">
                        No Vendor Lock-in
                    </h3>
                </div>
                <p class="text-text-tertiary">
                    Switch cloud providers or AI models anytime
                </p>
            </Card>

            <Card class="p-6">
                <div class="flex items-center mb-3">
                    <svg
                        class="w-6 h-6 text-accent-emerald mr-3"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"
                        ></path>
                    </svg>
                    <h3 class="text-lg font-bold text-text-primary">
                        Complete Privacy
                    </h3>
                </div>
                <p class="text-text-tertiary">
                    Your code never leaves your infrastructure
                </p>
            </Card>
        </div>
    </Section>

    <!-- CTA Section -->
    <section
        class="py-24 bg-gradient-to-b from-bg-primary to-bg-secondary text-text-primary"
    >
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h2
                class="text-4xl sm:text-5xl font-bold mb-6 bg-gradient-to-r from-accent-emerald to-accent-cyan bg-clip-text text-transparent"
            >
                Ready to Transform Your Business Operations?
            </h2>
            <p class="text-xl text-text-secondary mb-12 max-w-2xl mx-auto">
                nocodo is under active development. Star the project on GitHub
                to follow our progress and be notified of updates.
            </p>
            <a
                href="https://github.com/brainless/nocodo"
                class="inline-flex items-center px-10 py-5 bg-gradient-to-r from-emerald-500 to-cyan-500 hover:from-emerald-600 hover:to-cyan-600 text-white font-bold text-lg rounded-lg shadow-xl hover:shadow-2xl transition-all duration-200"
                target="_blank"
                rel="noopener noreferrer"
            >
                <svg
                    class="mr-3 w-7 h-7"
                    fill="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                    ></path>
                </svg>
                Star on GitHub
            </a>
            <p class="text-text-muted mt-8 text-sm">
                Privacy-focused • No vendor lock-in • Built for businesses of all sizes
            </p>
        </div>
    </section>

    <!-- Footer Note -->
    <section
        class="py-12 bg-bg-primary text-text-primary border-t border-border-secondary"
    >
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <p class="text-text-tertiary">
                Hello! I am Sumit, a software engineer living in a small
                Himalayan village in India.
            </p>
            <p class="text-text-tertiary mt-2">
                I am building nocodo to help businesses operate and scale using open source software,
                with AI assisting every team member in their daily work.
            </p>
        </div>
    </section>
</Layout>
